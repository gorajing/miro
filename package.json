{
  "name": "miro",
  "version": "0.0.1",
  "private": false,
  "description": "A cute desktop pet whose world is your computer — it watches your screen and reacts, powered by Gemma 4 31B on Cerebras.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "probe": "node --env-file=.env scripts/probe.mjs",
    "render:miro": "node --import tsx scripts/render-miro.ts",
    "overlay": "electron electron/main.mjs"
  },
  "dependencies": {
    "pixi.js": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.11"
  }
}
